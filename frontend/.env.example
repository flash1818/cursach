## Frontend (Vite) environment variables
## Copy to .env.local and edit if needed.
##
## Default behavior (without any .env):
## - API calls go to "/api" and are proxied by Vite to the Django backend (see vite.config.js)
## - Backend links (login/profile) open "http://localhost:8000"

# API base for frontend fetch calls.
# For local dev with Vite proxy you can keep it as "/api".
VITE_API_BASE=/api

# Django origin for links to HTML pages (login/register/profile).
VITE_BACKEND_ORIGIN=http://localhost:8000

# JavaScript API Яндекс.Карт (ключ с https://developer.tech.yandex.ru/ ).
# Без ключа карта может не загрузиться или работать с ограничениями.
# VITE_YANDEX_MAPS_API_KEY=

