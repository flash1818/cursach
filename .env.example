# Скопируйте в `.env` в корне проекта (файл не коммитить).

# Обязательно задайте свой ключ в продакшене:
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Опционально: PostgreSQL
# USE_POSTGRES=1
# POSTGRES_DB=realestate_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Фронтенд (сборка Vite): ключ Яндекс.Карт
# VITE_YANDEX_MAPS_API_KEY=
